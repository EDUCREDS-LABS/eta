# =============================================================================
# EduCreds Trust Agent - Ollama Multi-Model Configuration
# =============================================================================
# This configuration optimizes the Trust Agent to run entirely on-device
# with Ollama, providing local inference, privacy, and cost efficiency.
# =============================================================================

NODE_ENV=development
TRUST_AGENT_PORT=3010

# =============================================================================
# Primary LLM: Set to either 'ollama' or a hybrid strategy
# =============================================================================

# Option 1: Use Ollama as primary LLM (fully local)
# TRUST_AGENT_LLM_PROVIDER=ollama
# TRUST_AGENT_LLM_BASE_URL=http://localhost:11434/v1
# TRUST_AGENT_LLM_MODEL=mistral  # or neural-chat, llama2, dolphin-mixtral

# Option 2: Keep OpenAI/Mistral as primary but enable Ollama for specialized tasks
TRUST_AGENT_LLM_PROVIDER=openai
TRUST_AGENT_LLM_API_KEY=sk-proj-your-openai-key-here
TRUST_AGENT_LLM_BASE_URL=https://api.openai.com/v1
TRUST_AGENT_LLM_MODEL=gpt-4.1-mini

# =============================================================================
# Multi-Model Routing: Enable task-specific model selection
# =============================================================================
# When enabled, the Trust Agent intelligently routes different task types
# to the most suitable model:
#   - POIC_CALCULATION      → Ollama (consistent, local, fast)
#   - GOVERNANCE_ADVICE     → Mistral (strong reasoning) or Ollama
#   - CREDENTIAL_RISK_ANALYSIS → Mistral (analytical) or Ollama
#   - ETA_PROMPT            → Ollama (local & fast)
#   - FREEFORM              → Primary model (fallback)
# =============================================================================

TRUST_AGENT_MULTI_MODEL_ENABLED=true

# --- Ollama Configuration ---
# Ollama runs locally at http://localhost:11434 by default
# Download models with: ollama pull <model-name>
# Start Ollama server: ollama serve
TRUST_AGENT_OLLAMA_ENABLED=true
TRUST_AGENT_OLLAMA_BASE_URL=http://localhost:11434/v1
# Available models (all run locally):
#   - "mistral"          : 7B, fastest reasoning (recommended for governance)
#   - "neural-chat"      : 7B, good balance, optimized for conversation
#   - "llama2"           : 7B/13B, strong reasoning, slower
#   - "dolphin-mixtral"  : 45B, best reasoning but slower & more memory
#   - "orca-mini"        : 3B, lightweight, fastest
#   - "phi"              : 2.7B, ultra-lightweight
TRUST_AGENT_OLLAMA_MODEL=qwen2.5-coder:1.5b

# --- Mistral API Configuration (Optional Specialized Reasoning) ---
# Leave disabled for fully local setup; enable for enhanced governance analysis
TRUST_AGENT_MISTRAL_ENABLED=false
TRUST_AGENT_MISTRAL_API_KEY=your-mistral-api-key-here
TRUST_AGENT_MISTRAL_MODEL=mistral-small

# =============================================================================
# Frontend CORS Configuration
# =============================================================================
TRUST_AGENT_FRONTEND_URL=http://localhost:5002

# =============================================================================
# PoIC (Proof of Institutional Credibility) Configuration
# =============================================================================
TRUST_AGENT_POIC_LOCAL_PATH=../../../educreds-protocol/PoIC.md
TRUST_AGENT_POIC_LIVE_URL=https://docs.educreds.xyz/educreds/governance-institution-approval-and-poic-bootstrap/poic-computation
TRUST_AGENT_POIC_SYNC_ENABLED=true
TRUST_AGENT_POIC_SYNC_INTERVAL_MINUTES=360

# =============================================================================
# Recommended Model Selection by Use Case
# =============================================================================
# Full Local Setup (Privacy-First, Zero API Costs):
#   TRUST_AGENT_LLM_PROVIDER=ollama
#   TRUST_AGENT_OLLAMA_MODEL=mistral
#   TRUST_AGENT_MULTI_MODEL_ENABLED=true
#
# Hybrid Setup (Balance Speed & Quality):
#   TRUST_AGENT_LLM_PROVIDER=openai         # primary for complex queries
#   TRUST_AGENT_OLLAMA_ENABLED=true         # local for PoIC calculations
#   TRUST_AGENT_MISTRAL_ENABLED=true        # governance reasoning
#   TRUST_AGENT_MULTI_MODEL_ENABLED=true
#
# Cost-Optimized Setup (Minimize API Calls):
#   TRUST_AGENT_LLM_PROVIDER=ollama
#   TRUST_AGENT_OLLAMA_MODEL=neural-chat   # good quality/speed balance
#   TRUST_AGENT_OLLAMA_ENABLED=true
#   TRUST_AGENT_MULTI_MODEL_ENABLED=true
#
# High-Quality Setup (Best Results):
#   TRUST_AGENT_LLM_PROVIDER=openai
#   TRUST_AGENT_OLLAMA_MODEL=dolphin-mixtral  # fallback for local
#   TRUST_AGENT_MISTRAL_ENABLED=true
#   TRUST_AGENT_MULTI_MODEL_ENABLED=true
# =============================================================================
