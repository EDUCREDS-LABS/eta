NODE_ENV=production
TRUST_AGENT_PORT=3010

# LLM Provider Configuration
# Options: openai, mistral, gemini, ollama
TRUST_AGENT_LLM_PROVIDER=mistral

# PRIMARY LLM PROVIDER - UPDATE THIS WITH VALID API KEY
TRUST_AGENT_LLM_API_KEY=wAoRtxvHb7CV9kna7hKvZ3YLGMeHHXeT
TRUST_AGENT_LLM_BASE_URL=https://api.mistral.ai/v1
TRUST_AGENT_LLM_MODEL=mistral-large-2512

# Mirror key for backward compatibility
MISTRAL_API_KEY=your-valid-mistral-api-key-here

# PoIC (Proof of Institutional Credibility) Configuration
TRUST_AGENT_POIC_LOCAL_PATH=../../../educreds-protocol/PoIC.md
TRUST_AGENT_POIC_LIVE_URL=https://docs.educreds.xyz/educreds/governance-institution-approval-and-poic-bootstrap/poic-computation
TRUST_AGENT_POIC_SYNC_INTERVAL_MINUTES=360
TRUST_AGENT_POIC_SYNC_ENABLED=true

# CORS Configuration
TRUST_AGENT_ALLOWED_ORIGINS=https://educreds.xyz,https://www.educreds.xyz,http://localhost:3000

# Multi-Model Routing - Enables fallback support
TRUST_AGENT_MULTI_MODEL_ENABLED=true

# Ollama Configuration (Local, no API key required)
# Uncomment to enable Ollama as fallback
TRUST_AGENT_OLLAMA_ENABLED=true
TRUST_AGENT_OLLAMA_BASE_URL=http://localhost:11434/v1
TRUST_AGENT_OLLAMA_MODEL=mistral

# Mistral Specialized Reasoning
TRUST_AGENT_MISTRAL_ENABLED=true
TRUST_AGENT_MISTRAL_API_KEY=your-valid-mistral-api-key-here
TRUST_AGENT_MISTRAL_MODEL=mistral-small
