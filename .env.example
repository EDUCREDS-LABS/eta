NODE_ENV=development
TRUST_AGENT_PORT=3010

# If you already have OPENAI_API_KEY at the root or in cert_backend/.env
# you can re-use it; otherwise set a dedicated key here.
TRUST_AGENT_LLM_PROVIDER=openai
TRUST_AGENT_LLM_API_KEY=your-openai-or-mistral-api-key
TRUST_AGENT_LLM_BASE_URL=https://api.openai.com/v1
TRUST_AGENT_LLM_MODEL=gpt-4.1-mini
TRUST_AGENT_MAX_CONCURRENT_LLM_REQUESTS=4
TRUST_AGENT_LLM_REQUEST_TIMEOUT_MS=30000
TRUST_AGENT_RATE_LIMIT_WINDOW_MS=60000
TRUST_AGENT_RATE_LIMIT_MAX=60
TRUST_AGENT_API_KEY=

# Allow any origin in local dev; set a specific origin in staging/prod.
TRUST_AGENT_FRONTEND_URL=http://localhost:5002

# PoIC (Proof of Institutional Credibility) Configuration
# Local path relative to educreds_trust_agent root (fallback for reliability)
TRUST_AGENT_POIC_LOCAL_PATH=../../../educreds-protocol/PoIC.md
# Live documentation URL (auto-updates when docs are published)
TRUST_AGENT_POIC_LIVE_URL=https://docs.educreds.xyz/educreds/governance-institution-approval-and-poic-bootstrap/poic-computation
# Periodic sync interval in minutes (recommended: 360 = 6 hours)
TRUST_AGENT_POIC_SYNC_INTERVAL_MINUTES=360
# Enable/disable automatic periodic sync of PoIC documentation (default: true)
TRUST_AGENT_POIC_SYNC_ENABLED=true
